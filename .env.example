# Google Gemini (required for topic suggestions)
GOOGLE_API_KEY=
# Optional model override (defaults to gemini-2.5-flash from config YAML)
GEMINI_MODEL=gemini-2.5-flash

# M2M API auth (required)
ADMIN_API_KEY=

# Backend CORS (comma-separated origins)
# CORS_ORIGINS=https://example.com

UVICORN_WORKERS=7
